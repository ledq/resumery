{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "resume.json",
  "type": "object",
  "required": ["skills", "experience"],
  "additionalProperties": false,
  "properties": {
    "skills": {
      "type": "array",
      "description": "Technical skills grouped by category, most JD-relevant category first.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["category", "items"],
        "additionalProperties": false,
        "properties": {
          "category": { "type": "string" },
          "items": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "experience": {
      "type": "array",
      "description": "Selected roles, most JD-relevant first.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role_id", "bullets"],
        "additionalProperties": false,
        "properties": {
          "role_id": {
            "type": "string",
            "description": "One of the role ids from the candidate profile."
          },
          "title_choice": {
            "type": "string",
            "description": "Optional. A provided title variant for this role, if one fits the JD better than the default. Omit to use the default."
          },
          "bullets": {
            "type": "array",
            "description": "Plain-text bullets, one story each.",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    },
    "projects": {
      "type": "array",
      "description": "Optional. Omit to drop the section if exceed max page limit.",
      "items": {
        "type": "object",
        "required": ["name", "bullets"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "stack": { "type": "string", "description": "Optional. Technologies used, shown after the name." },
          "dates": { "type": "string", "description": "Optional." },
          "bullets": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "relevant_coursework": {
      "type": "array",
      "description": "Optional. Include only when the JD requires a skill with no evidence in experience or projects. Keep minimal.",
      "items": { "type": "string" }
    }
  }
}